    "def predict(sentence, model, max_length=10):\n",
    "    with torch.no_grad():\n",
    "        model.eval()\n",
    "        src_tokens = [token.vector for token in nlp(sentence)]\n",
    "        src_tokens = torch.tensor([src_tokens[:max_length] + [np.zeros(src_tokens[0].shape)] * (max_length - len(src_tokens))], dtype=torch.float32)\n",
    "\n",
    "        # Ensure tgt_tokens have the correct shape [batch_size, seq_len, embedding_dim]\n",
    "        tgt_tokens = torch.zeros((1, max_length, src_tokens.shape[-1]), dtype=torch.float32)\n",
    "\n",
    "        print(\"src_tokens shape:\", src_tokens.shape)\n",
    "        print(\"tgt_tokens shape:\", tgt_tokens.shape)\n",
    "\n",
    "        # Pass through the model\n",
    "        output = model(src_tokens, tgt_tokens)\n",
    "\n",
    "        # Extract predicted vector from the output\n",
    "        predicted_vector = output[0, -1, :].numpy()\n",
    "\n",
    "        return predicted_vector\n"
   ]
