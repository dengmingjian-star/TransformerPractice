    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader\n",
    "\n",
    "# 确保spacy模型输出的维度一致\n",
    "input_dim = nlp(\"我\").vector.shape[0]  # 从spacy获取的词嵌入的维度\n",
    "hidden_dim = 256\n",
    "ff_dim = 512  # 前馈神经网络的中间维度\n",
    "n_layers = 2\n",
    "n_heads = 8\n",
    "max_len = 100  # 设置最大序列长度\n",
    "\n",
    "# 初始化模型，数据集，数据加载器和训练设置\n",
    "model = TransformerModel(input_dim, n_heads, ff_dim, n_layers, n_layers, max_len=max_len)\n",
    "dataset = TranslationDataset(train_data)\n",
    "dataloader = DataLoader(dataset, batch_size=1, shuffle=True)\n",
    "\n",
    "criterion = nn.MSELoss()  # 损失函数\n",
    "optimizer = optim.Adam(model.parameters(), lr=0.001)  # 优化器"
   ]
